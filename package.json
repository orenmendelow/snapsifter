{
  "name": "drkrm",
  "version": "1.0.0-beta",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "build": "electron-builder --mac && ./scripts/resign-app.sh",
    "build:helper": "./scripts/build-helper.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["fujifilm", "film-simulation", "recipe", "photo-culling", "raw", "x-series"],
  "author": "Mendelow LLC <mendelowllc@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "description": "Photo culling and Fujifilm film simulation recipe tool for macOS",
  "dependencies": {
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "node-addon-api": "^8.7.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "@electron/notarize": "^3.0.0",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.mendelow.drkrm",
    "productName": "drkrm",
    "asar": false,
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "extraResources": [
        {
          "from": "camera-helper/.build/release/camera-helper",
          "to": "camera-helper"
        }
      ]
    },
    "dmg": {
      "title": "drkrm",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "electron-main.js",
      "server.js",
      "camera-bridge.js",
      "lib/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "afterSign": "scripts/notarize.js"
  }
}
